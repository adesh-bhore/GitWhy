# GitWhy Environment Variables
# Copy this to .env and fill in your values

# Backend API URL (default: your hosted backend)
# GITWHY_API_URL=http://51.21.226.149:3000

# PostgreSQL connection (optional - only if using PostgreSQL backend)
# DATABASE_URL=postgresql://localhost:5432/gitwhy

# Feature flag: Use PostgreSQL instead of JSON (optional)
# GITWHY_USE_POSTGRES=false

# Server-side only (NOT needed by CLI users)
# GROQ_API_KEY=your_groq_api_key_here
# COHERE_API_KEY=your_cohere_api_key_here
# VOYAGE_API_KEY=your_voyage_api_key_here
